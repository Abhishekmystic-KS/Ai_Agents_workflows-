# Google Gemini API Key (Get a key from https://aistudio.google.com/)
GEMINI_API_KEY=your_gemini_api_key_here

# Model to use (e.g., gemini-2.5-flash, gemini-2.5-pro, etc.)
GEMINI_MODEL=gemini-2.5-flash

# Model Temperature (higher is more creative, lower is more deterministic/precise)
GEMINI_TEMPERATURE=0.2

# Maximum step limit for the agent loop to prevent run-away infinite loops
MAX_STEPS=5
